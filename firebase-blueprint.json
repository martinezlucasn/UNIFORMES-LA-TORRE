{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for sale in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "purchasePrice": { "type": "number", "description": "Cost price of the product" },
        "sellingPrice": { "type": "number", "description": "Price at which the product is sold" },
        "details": { "type": "string", "description": "Additional details or description" },
        "stock": { "type": "number", "description": "Current quantity in stock" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was added" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the product was last updated" }
      },
      "required": ["name", "purchasePrice", "sellingPrice", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed sales transaction/receipt",
      "type": "object",
      "properties": {
        "receiptNumber": { "type": "string", "description": "Unique identifier for the receipt" },
        "customerName": { "type": "string", "description": "Name of the customer (optional)" },
        "items": {
          "type": "array",
          "description": "List of products sold in this transaction"
        },
        "subtotal": { "type": "number", "description": "Total sum before surcharges" },
        "surcharge": { "type": "number", "description": "Extra fee (e.g. 10% for card payment)" },
        "total": { "type": "number", "description": "Final amount paid" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card", "transfer"] },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the sale occurred" }
      },
      "required": ["receiptNumber", "items", "subtotal", "total", "paymentMethod", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products in inventory"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of all sales records"
    }
  }
}
